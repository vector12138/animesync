{
  "app": {
    "name": "AnimeSync",
    "host": "0.0.0.0",
    "port": 8000,
    "debug": true
  },
  "database": {
    "url": "sqlite:///./animesync.db"
  },
  "jwt": {
    "secret_key": "change-this-in-production",
    "algorithm": "HS256",
    "access_token_expire_minutes": 1440
  },
  "logging": {
    "level": "INFO",
    "file": "logs/animesync.log",
    "max_bytes": 10485760,
    "backup_count": 3,
    "format": "[%(asctime)s] [%(levelname)s] [%(name)s] %(message)s"
  }
}